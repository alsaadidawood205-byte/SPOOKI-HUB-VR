    elseif selectedColor == "أصفر" then return Color3.fromRGB(255,255,0)
    elseif selectedColor == "وردي" then return Color3.fromRGB(255,105,180)
    elseif selectedColor == "بنفسجي" then return Color3.fromRGB(128,0,128)
    end
    return Color3.new(1,1,1)
