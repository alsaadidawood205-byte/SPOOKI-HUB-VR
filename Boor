RunService.Stepped:Connect(function()
    pcall(function()
        if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local hrp, hum = lp.Character.HumanoidRootPart, lp.Character:FindFirstChild("Humanoid")
            if antiGlitchEnabled then
                hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                local params = OverlapParams.new()
                params.FilterType = Enum.RaycastFilterType.Exclude
                params.FilterDescendantsInstances = {lp.Character}
                for _, obj in pairs(workspace:GetPartBoundsInRadius(hrp.Position, 30, params)) do
                    if obj:IsA("BasePart") then
                        if not (Players:GetPlayerFromCharacter(obj.Parent) or Players:GetPlayerFromCharacter(obj.Parent.Parent)) then
                            if obj:FindFirstAncestorOfClass("VehicleSeat") or obj.Name:lower():find("car") or obj.AssemblyLinearVelocity.Magnitude > 15 then obj.CanCollide = false end
                        end
                    end
                end
            end
            if antiSitEnabled and hum then hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false); hum.Sit = false end
            if antiFlingAll then for _, part in pairs(lp.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end end
        end
    end)
end)

RunService.Heartbeat:Connect(function()
    pcall(function()
        if (bangEnabled or faceSitEnabled or combinedEnabled) and bangTarget and bangTarget.Character then
            local targetChar = bangTarget.Character
            local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
            if not targetHRP then return end
            if not originalCFrame then originalCFrame = lp.Character.HumanoidRootPart.CFrame end
            local hrp = lp.Character.HumanoidRootPart
            if holdSixTools then EquipSixSimultaneously() end
            local wave = math.sin(tick() * 55) 
            local deepRecoil, normalRecoil = wave * 4.5, wave * 2.5
            hrp.Velocity = Vector3.new(0, 0, 0)
            for _, v in pairs(lp.Character:GetChildren()) do if v:IsA("BasePart") then v.CanCollide = false end end
            if combinedEnabled then
                if math.floor(tick() * 60) % 2 == 0 then lp.Character.Humanoid.Sit = true; hrp.CFrame = targetChar.Head.CFrame * CFrame.new(0, -0.6, deepRecoil) * CFrame.Angles(0, math.rad(180), 0)
                else lp.Character.Humanoid.Sit = false; hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0.5, deepRecoil + 1.5) end
            elseif faceSitEnabled then lp.Character.Humanoid.Sit = true; hrp.CFrame = targetChar.Head.CFrame * CFrame.new(0, -0.6, deepRecoil) * CFrame.Angles(0, math.rad(180), 0)
            elseif bangEnabled then lp.Character.Humanoid.Sit = false; hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0.5, normalRecoil + 1.2) end
        else
            if originalCFrame then lp.Character.HumanoidRootPart.CFrame = originalCFrame; originalCFrame = nil; lp.Character.Humanoid.Sit = false end
        end
    end)
end)

