BangTab:CreateToggle({ Name = "تفعيل بانق v2 كل الجسد 💥", CurrentValue = false, Flag = "TargetFlingV2", Callback = function(Value)
    TargetBangV2Enabled = Value
    local char, hrp, hum = lp.Character, lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"), lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if TargetBangV2Enabled then
        if not bangTarget or not bangTarget.Character then TargetBangV2Enabled = false; return end
        BangOriginalPos = hrp.CFrame; hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        TargetBangV2Connection = RunService.Heartbeat:Connect(function()
            if not TargetBangV2Enabled or not bangTarget.Character then return end
            local targetParts = {}
            for _, p in pairs(bangTarget.Character:GetChildren()) do if p:IsA("BasePart") then table.insert(targetParts, p) end end
            local randomPart = targetParts[math.random(1, #targetParts)]
            if not randomPart then return end
            for _, part in pairs(char:GetChildren()) do if part:IsA("BasePart") then part.CanCollide = false end end
            hrp.CFrame = randomPart.CFrame * CFrame.new(Vector3.new(math.random(-1,1), math.random(-1,1), math.random(-1,1))) * CFrame.Angles(math.rad(math.random(0,360)), math.rad(math.random(0,360)), math.rad(math.random(0,360)))
            hrp.Velocity, hrp.RotVelocity = Vector3.new(20000, 20000, 20000), Vector3.new(50000, 50000, 50000)
        end)
    else
        if TargetBangV2Connection then TargetBangV2Connection:Disconnect() end
        if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true); hum.Sit = false end
        if hrp then hrp.Velocity, hrp.RotVelocity = Vector3.new(0,0,0), Vector3.new(0,0,0); if BangOriginalPos then hrp.CFrame = BangOriginalPos end end
        if char then for _, part in pairs(char:GetChildren()) do if part:IsA("BasePart") then part.CanCollide = true end end end
    end
end})
