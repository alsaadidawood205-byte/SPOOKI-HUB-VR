local function AbsoluteNuke(v)
    if not _G.GlobalPurge then return end
    pcall(function()
        if v:IsA("Humanoid") or v:IsA("Terrain") or v:IsA("Shirt") or v:IsA("Pants") then return end
        if v.Name == "Baseplate" or v.Name == "Road" then return end
        if v:IsDescendantOf(lp.Character) and not v:IsA("Tool") then return end
        if v:IsA("Tool") or v:IsA("HopperBin") or v:IsA("Light") or v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") or v:IsA("ParticleEmitter") or v:IsA("Explosion") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Decal") or v:IsA("Texture") then v:Destroy() return end
        if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic; v.CastShadow = false; v.Reflectance = 0 end
    end)
end

