local function GetPlayerMatch(text)
    local searchText = text:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #searchText) == searchText or p.DisplayName:lower():sub(1, #searchText) == searchText then
            if p ~= lp then return p end
        end
    end
    return nil
end

local function EquipSixSimultaneously()
    if not lp.Character then return end
    local tools = lp.Backpack:GetChildren()
    local count = 0
    for _, tool in ipairs(tools) do
        if tool:IsA("Tool") and count < 6 then tool.Parent = lp.Character; count = count + 1 end
    end
end

